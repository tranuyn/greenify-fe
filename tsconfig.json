{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "api/*": ["./api/*"],
      "app/*": ["./app/*"],
      "assets/*": ["./assets/*"],
      "components/*": ["./components/*"],
      "constants/*": ["./constants/*"],
      "hooks/*": ["./hooks/*"],
      "lib/*": ["./lib/*"],
      "locales/*": ["./locales/*"],
      "services/*": ["./services/*"],
      "store/*": ["./store/*"],
      "types/*": ["./types/*"],
      "utils/*": ["./utils/*"],
      "validations/*": ["./validations/*"]
    }
  }
}
